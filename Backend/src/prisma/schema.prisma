generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Session {
  id        String   @id @default(cuid())
  sid       String   @unique
  data      String
  expiresAt DateTime
}

model User {
  id          String        @id @default(uuid())
  email       String        @unique
  password    String
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  username    String        @unique
  leaderboard LeaderBoard[]
  logs        Logs[]
}

model Game {
  id           String             @id @default(uuid())
  level        Int                @unique @default(autoincrement())
  difficulty   Difficulty
  characters   CharactersOnGame[]
  leaderboards LeaderBoard[]
  logs         Logs[]
  image        MainImage?
  result       Results[]
}

model MainImage {
  id      String @id @unique @default(uuid())
  src     String
  game_id String @unique
  game    Game   @relation(fields: [game_id], references: [id])
}

model Characters {
  id      String             @id @unique @default(uuid())
  name    String             @unique
  image   String             @unique
  games   CharactersOnGame[]
  results Results[]
}

model CharactersOnGame {
  game_id   String
  char_id   String
  character Characters @relation(fields: [char_id], references: [id])
  game      Game       @relation(fields: [game_id], references: [id])

  @@id([game_id, char_id])
}

model Results {
  id        String     @unique @default(uuid())
  game_id   String
  char_id   String
  pos_x     Int
  pos_y     Int
  character Characters @relation(fields: [char_id], references: [id])
  game      Game       @relation(fields: [game_id], references: [id])

  @@unique([game_id, char_id])
}

model Logs {
  id      String   @unique @default(uuid())
  game_id String
  user_id String
  start   DateTime @default(now())
  end     DateTime
  game    Game     @relation(fields: [game_id], references: [id])
  user    User     @relation(fields: [user_id], references: [id])
}

model LeaderBoard {
  id      String @unique @default(uuid())
  user_id String
  game_id String
  comment String
  time    Int
  game    Game   @relation(fields: [game_id], references: [id])
  user    User   @relation(fields: [user_id], references: [id])
}

enum Difficulty {
  Easy
  Medium
  Hard
}
